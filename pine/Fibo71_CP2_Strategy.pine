// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Fibo71 Bot - CP 2.0 Strategy

//@version=5
indicator("Fibo 71 CP 2.0 - BOS + Imbalance", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

// Fibonacci Settings
fibEntryMin = input.float(0.71, "Fib Entry Min", minval=0.5, maxval=0.95, step=0.01, group="Fibonacci")
fibEntryMax = input.float(0.79, "Fib Entry Max", minval=0.5, maxval=0.95, step=0.01, group="Fibonacci")

// BOS Settings
bosLookback = input.int(50, "BOS Lookback", minval=10, maxval=200, group="BOS Detection")
swingLookback = input.int(5, "Swing Lookback (bars)", minval=3, maxval=20, group="BOS Detection")
minImbalancePips = input.float(10.0, "Min Imbalance (pips)", minval=1, group="BOS Detection")

// Filters
enableImbalance = input.bool(true, "Require Imbalance", group="Filters")
enableLiquiditySweep = input.bool(true, "Require Liquidity Sweep", group="Filters")

// Setup Duration
setupExpiryBars = input.int(500, "Setup Expiry (bars)", minval=5, maxval=5000, step=5, tooltip="Number of candles setup stays active. After this many bars, fib lines are removed and listening stops. Default 500 = almost never expires.", group="Setup Duration")
setupExpiryEnabled = input.bool(true, "Enable Setup Expiry", group="Setup Duration")

// Display Settings
showSwingPoints = input.bool(true, "Show Swing Points", group="Display")
showFibLines = input.bool(true, "Show Fibonacci Lines", group="Display")
showLabels = input.bool(true, "Show Labels", group="Display")
showEntryZone = input.bool(true, "Show Entry Zone", group="Display")
maxActiveSetups = input.int(5, "Max Active Setups", minval=1, maxval=10, group="Display")

// Colors
colorBullish = input.color(color.green, "Bullish Color", group="Colors")
colorBearish = input.color(color.red, "Bearish Color", group="Colors")
colorEntryZone = input.color(color.new(color.blue, 80), "Entry Zone Color", group="Colors")
colorFib0 = input.color(color.lime, "Fib 0% (TP)", group="Colors")
colorFib236 = input.color(color.new(color.gray, 50), "Fib 23.6%", group="Colors")
colorFib382 = input.color(color.new(color.gray, 50), "Fib 38.2%", group="Colors")
colorFib50 = input.color(color.new(color.blue, 50), "Fib 50%", group="Colors")
colorFib618 = input.color(color.new(color.gray, 50), "Fib 61.8%", group="Colors")
colorFib100 = input.color(color.red, "Fib 100% (SL)", group="Colors")
colorImbalance = input.color(color.new(color.purple, 70), "Imbalance Zone", group="Colors")

// ═══════════════════════════════════════════════════════════════════════════════
// TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Setup type to store active trade setup
type Setup
    bool isBullish           // Direction
    float fib0               // TP level
    float fib236
    float fib382
    float fib50
    float fib618
    float fib100             // SL level
    float fib71              // Entry zone top
    float fib79              // Entry zone bottom
    int createdBar           // Bar when created
    int hitBar               // Bar when TP/SL hit (na if active)
    bool hitTP               // true=TP, false=SL
    line lineFib0
    line lineFib100
    line lineFib50
    line lineFib71
    line lineFib79
    box entryZoneBox
    label bosLabel

// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════

var float swingHigh = na
var float swingLow = na
var int swingHighIdx = na
var int swingLowIdx = na

// Array of active setups
var Setup[] activeSetups = array.new<Setup>()

// ═══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Delete all drawing objects for a setup
deleteSetupDrawings(Setup s) =>
    line.delete(s.lineFib0)
    line.delete(s.lineFib100)
    line.delete(s.lineFib50)
    line.delete(s.lineFib71)
    line.delete(s.lineFib79)
    box.delete(s.entryZoneBox)
    label.delete(s.bosLabel)

// Create drawing objects for a setup
createSetupDrawings(Setup s, bool showFib, bool showZone, bool showLbl) =>
    if showFib
        s.lineFib0 := line.new(s.createdBar, s.fib0, bar_index + 1, s.fib0, color=colorFib0, width=2, style=line.style_solid, extend=extend.right)
        s.lineFib100 := line.new(s.createdBar, s.fib100, bar_index + 1, s.fib100, color=colorFib100, width=2, style=line.style_solid, extend=extend.right)
        s.lineFib50 := line.new(s.createdBar, s.fib50, bar_index + 1, s.fib50, color=colorFib50, width=1, style=line.style_solid, extend=extend.right)

        if showZone
            s.lineFib71 := line.new(s.createdBar, s.fib71, bar_index + 1, s.fib71, color=color.new(color.blue, 50), width=1, style=line.style_dotted, extend=extend.right)
            s.lineFib79 := line.new(s.createdBar, s.fib79, bar_index + 1, s.fib79, color=color.new(color.blue, 50), width=1, style=line.style_dotted, extend=extend.right)
            zoneColor = s.isBullish ? color.new(color.green, 90) : color.new(color.red, 90)
            s.entryZoneBox := box.new(s.createdBar, s.fib71, bar_index + 1, s.fib79, bgcolor=zoneColor, border_color=na)

    if showLbl
        lblText = s.isBullish ?
            "🟢 BULLISH BOS\nTP: " + str.tostring(s.fib0, "#.#####") + "\nEntry: " + str.tostring(s.fib79, "#.#####") + " - " + str.tostring(s.fib71, "#.#####") + "\nSL: " + str.tostring(s.fib100, "#.#####") :
            "🔴 BEARISH BOS\nTP: " + str.tostring(s.fib0, "#.#####") + "\nEntry: " + str.tostring(s.fib71, "#.#####") + " - " + str.tostring(s.fib79, "#.#####") + "\nSL: " + str.tostring(s.fib100, "#.#####")
        lblColor = s.isBullish ? color.new(color.green, 30) : color.new(color.red, 30)
        lblStyle = s.isBullish ? label.style_label_up : label.style_label_down
        lblY = s.isBullish ? s.fib100 : s.fib100
        s.bosLabel := label.new(s.createdBar, lblY, lblText, color=lblColor, textcolor=color.white, style=lblStyle, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// SWING POINT DETECTION (Configurable lookback)
// ═══════════════════════════════════════════════════════════════════════════════

// Find swing high (higher than N candles on each side)
isSwingHigh = true
isSwingLow = true

for i = 1 to swingLookback
    if bar_index - i >= 0  // Ensure we don't go before first bar
        isSwingHigh := isSwingHigh and high[i] < high
        isSwingLow := isSwingLow and low[i] > low

// Check future candles (only if not on last bar)
if barstate.isrealtime or bar_index < bar_index - swingLookback
    for i = 1 to swingLookback
        if bar_index + i <= bar_index  // Check if future bar exists
            isSwingHigh := isSwingHigh and high[max(0, i)] < high
            isSwingLow := isSwingLow and low[max(0, i)] > low

if isSwingHigh
    swingHigh := high
    swingHighIdx := bar_index

if isSwingLow
    swingLow := low
    swingLowIdx := bar_index

// ═══════════════════════════════════════════════════════════════════════════════
// BREAK OF STRUCTURE (BOS) DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

// Bearish BOS: price closes below previous swing low
bearishBOS = not na(swingLow) and close < swingLow and bar_index - swingLowIdx <= bosLookback and bar_index - swingLowIdx >= 3

// Bullish BOS: price closes above previous swing high
bullishBOS = not na(swingHigh) and close > swingHigh and bar_index - swingHighIdx <= bosLookback and bar_index - swingHighIdx >= 3

// ═══════════════════════════════════════════════════════════════════════════════
// IMBALANCE (IPA) DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

pipMultiplier = syminfo.mintick * 10

bearishImbalance = low[2] > high and (low[2] - high) >= minImbalancePips * pipMultiplier
bullishImbalance = high[2] < low and (low - high[2]) >= minImbalancePips * pipMultiplier

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

lookbackSweep = 5
bullishLiquiditySweep = false
bearishLiquiditySweep = false

if bearishBOS
    for i = 1 to lookbackSweep
        if high[i] > swingHigh and close[i] < swingHigh
            bearishLiquiditySweep := true
            break

if bullishBOS
    for i = 1 to lookbackSweep
        if low[i] < swingLow and close[i] > swingLow
            bullishLiquiditySweep := true
            break

// ═══════════════════════════════════════════════════════════════════════════════
// CHECK IF NEW BOS MEETS CRITERIA
// ═══════════════════════════════════════════════════════════════════════════════

newBearishSetup = bearishBOS and (not enableImbalance or bearishImbalance) and (not enableLiquiditySweep or bearishLiquiditySweep)
newBullishSetup = bullishBOS and (not enableImbalance or bullishImbalance) and (not enableLiquiditySweep or bullishLiquiditySweep)

// ═══════════════════════════════════════════════════════════════════════════════
// CHECK EXISTING SETUPS FOR TP/SL HIT
// ═══════════════════════════════════════════════════════════════════════════════

// Loop through active setups and check if TP or SL was hit
int i = 0
while i < array.size(activeSetups)
    Setup s = array.get(activeSetups, i)

    // Only check active setups (not yet hit)
    if na(s.hitBar)
        // Check if setup has expired (duration exceeded)
        isExpired = setupExpiryEnabled and (bar_index - s.createdBar >= setupExpiryBars)

        if isExpired
            // Setup expired - delete all drawings and mark as expired
            deleteSetupDrawings(s)
            s.hitBar := bar_index
            s.hitTP := na  // na means expired (not TP or SL)
            if showLabels
                s.bosLabel := label.new(bar_index, s.isBullish ? s.fib100 : s.fib100, "⏰ EXPIRED", color=color.new(color.gray, 30), textcolor=color.white, style=s.isBullish ? label.style_label_down : label.style_label_up, size=size.tiny)

        else
            // Check if price hit TP or SL
            hitTP_level = s.isBullish ? (low <= s.fib0) : (high >= s.fib0)
            hitSL_level = s.isBullish ? (high >= s.fib100) : (low <= s.fib100)

            if hitTP_level
                s.hitBar := bar_index
                s.hitTP := true
                // Update label to show TP hit
                if showLabels
                    label.delete(s.bosLabel)
                    hitText = s.isBullish ? "✅ TP HIT" : "✅ TP HIT"
                    lblColor = color.new(color.lime, 20)
                    s.bosLabel := label.new(bar_index, s.fib0, hitText, color=lblColor, textcolor=color.black, style=label.style_label_up, size=size.normal)
                // Change line colors to show inactive
                if showFibLines
                    line.set_style(s.lineFib0, line.style_solid)
                    line.set_width(s.lineFib0, 3)

            else if hitSL_level
                s.hitBar := bar_index
                s.hitTP := false
                // Update label to show SL hit
                if showLabels
                    label.delete(s.bosLabel)
                    hitText = s.isBullish ? "⛔ SL HIT" : "⛔ SL HIT"
                    lblColor = color.new(color.red, 20)
                    s.bosLabel := label.new(bar_index, s.fib100, hitText, color=lblColor, textcolor=color.white, style=label.style_label_down, size=size.normal)
                // Change line colors to show inactive
                if showFibLines
                    line.set_style(s.lineFib100, line.style_solid)
                    line.set_width(s.lineFib100, 3)

    i := i + 1

// ═══════════════════════════════════════════════════════════════════════════════
// CREATE NEW SETUP IF BOS DETECTED
// ═══════════════════════════════════════════════════════════════════════════════

if newBearishSetup and showFibLines
    // Calculate Fibonacci levels for bearish
    float b_fib0 = swingLow      // TP
    float b_fib100 = swingHigh   // SL
    float range_size = swingHigh - swingLow
    float b_fib236 = swingLow + range_size * 0.236
    float b_fib382 = swingLow + range_size * 0.382
    float b_fib50 = swingLow + range_size * 0.5
    float b_fib618 = swingLow + range_size * 0.618
    float b_fib71 = swingLow + range_size * fibEntryMin
    float b_fib79 = swingLow + range_size * fibEntryMax

    // Create new setup
    Setup newSetup = Setup.new(
         false,           // isBullish
         b_fib0,          // fib0 (TP)
         b_fib236,        // fib236
         b_fib382,        // fib382
         b_fib50,         // fib50
         b_fib618,        // fib618
         b_fib100,        // fib100 (SL)
         b_fib71,         // fib71
         b_fib79,         // fib79
         bar_index,       // createdBar
         na,              // hitBar (na = active)
         false,           // hitTP
         na, na, na, na, na, na, na  // Drawing objects (created below)
    )

    createSetupDrawings(newSetup, showFibLines, showEntryZone, showLabels)
    array.push(activeSetups, newSetup)

    // Limit number of active setups
    while array.size(activeSetups) > maxActiveSetups
        Setup old = array.shift(activeSetups)
        deleteSetupDrawings(old)

    // Alert
    alert("🔴 BEARISH BOS detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(b_fib71, "#.#####") + " - " + str.tostring(b_fib79, "#.#####") + "\nTP: " + str.tostring(b_fib0, "#.#####") + " | SL: " + str.tostring(b_fib100, "#.#####"), alert.freq_once_per_bar_close)

if newBullishSetup and showFibLines
    // Calculate Fibonacci levels for bullish
    float b_fib0 = swingHigh     // TP
    float b_fib100 = swingLow    // SL
    float range_size = swingHigh - swingLow
    float b_fib236 = swingHigh - range_size * 0.236
    float b_fib382 = swingHigh - range_size * 0.382
    float b_fib50 = swingHigh - range_size * 0.5
    float b_fib618 = swingHigh - range_size * 0.618
    float b_fib71 = swingHigh - range_size * fibEntryMin
    float b_fib79 = swingHigh - range_size * fibEntryMax

    // Create new setup
    Setup newSetup = Setup.new(
         true,            // isBullish
         b_fib0,          // fib0 (TP)
         b_fib236,        // fib236
         b_fib382,        // fib382
         b_fib50,         // fib50
         b_fib618,        // fib618
         b_fib100,        // fib100 (SL)
         b_fib71,         // fib71
         b_fib79,         // fib79
         bar_index,       // createdBar
         na,              // hitBar (na = active)
         false,           // hitTP
         na, na, na, na, na, na, na  // Drawing objects (created below)
    )

    createSetupDrawings(newSetup, showFibLines, showEntryZone, showLabels)
    array.push(activeSetups, newSetup)

    // Limit number of active setups
    while array.size(activeSetups) > maxActiveSetups
        Setup old = array.shift(activeSetups)
        deleteSetupDrawings(old)

    // Alert
    alert("🟢 BULLISH BOS detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(b_fib79, "#.#####") + " - " + str.tostring(b_fib71, "#.#####") + "\nTP: " + str.tostring(b_fib0, "#.#####") + " | SL: " + str.tostring(b_fib100, "#.#####"), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAW SWING POINTS
// ═══════════════════════════════════════════════════════════════════════════════

if showSwingPoints
    if isSwingHigh
        label.new(bar_index, high, "HH", color=color.new(color.red, 50), textcolor=color.white, style=label.style_label_down, size=size.tiny)
    if isSwingLow
        label.new(bar_index, low, "LL", color=color.new(color.green, 50), textcolor=color.white, style=label.style_label_up, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// PRICE IN ENTRY ZONE ALERT
// ═══════════════════════════════════════════════════════════════════════════════

// Check if price is in any active entry zone
for Setup s in activeSetups
    if na(s.hitBar)  // Only active setups
        inZone = s.isBullish ? (close <= s.fib71 and close >= s.fib79) : (close >= s.fib79 and close <= s.fib71)
        if inZone
            alert("📍 Price in Entry Zone on " + syminfo.ticker + " | Price: " + str.tostring(close, "#.#####"), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "CP 2.0 Status", text_color=color.white, bgcolor=color.new(color.blue, 60))

    // Count active setups
    activeBullish = 0
    activeBearish = 0
    for Setup s in activeSetups
        if na(s.hitBar)
            if s.isBullish
                activeBullish += 1
            else
                activeBearish += 1

    statusText = activeBullish > 0 ? "🟢 BULLISH x" + str.tostring(activeBullish) : activeBearish > 0 ? "🔴 BEARISH x" + str.tostring(activeBearish) : "⚪ NEUTRAL"
    table.cell(infoTable, 1, 0, statusText, text_color=color.white)

    // Show most recent active setup details
    if activeBullish > 0 or activeBearish > 0
        Setup lastActive = na
        for i = array.size(activeSetups) - 1 to 0
            Setup s = array.get(activeSetups, i)
            if na(s.hitBar)
                lastActive := s
                break

        if not na(lastActive)
            table.cell(infoTable, 0, 1, "TP (0%)", text_color=color.lime)
            table.cell(infoTable, 1, 1, str.tostring(lastActive.fib0, "#.#####"), text_color=color.lime)

            table.cell(infoTable, 0, 2, "50%", text_color=color.blue)
            table.cell(infoTable, 1, 2, str.tostring(lastActive.fib50, "#.#####"), text_color=color.blue)

            table.cell(infoTable, 0, 3, "Entry Zone", text_color=color.blue)
            entryText = lastActive.isBullish ?
                str.tostring(lastActive.fib79, "#.#####") + " - " + str.tostring(lastActive.fib71, "#.#####") :
                str.tostring(lastActive.fib71, "#.#####") + " - " + str.tostring(lastActive.fib79, "#.#####")
            table.cell(infoTable, 1, 3, entryText, text_color=color.blue)

            table.cell(infoTable, 0, 4, "SL (100%)", text_color=color.red)
            table.cell(infoTable, 1, 4, str.tostring(lastActive.fib100, "#.#####"), text_color=color.red)

            table.cell(infoTable, 0, 5, "Active Setups", text_color=color.white)
            table.cell(infoTable, 1, 5, str.tostring(activeBullish + activeBearish) + "/" + str.tostring(maxActiveSetups), text_color=color.white)

            // Show expiry countdown
            if setupExpiryEnabled
                barsLeft = setupExpiryBars - (bar_index - lastActive.createdBar)
                expiryColor = barsLeft <= 5 ? color.orange : color.white
                table.cell(infoTable, 0, 6, "Expires in", text_color=color.white)
                table.cell(infoTable, 1, 6, str.tostring(barsLeft) + " bars", text_color=expiryColor)
