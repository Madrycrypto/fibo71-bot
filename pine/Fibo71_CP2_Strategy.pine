// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Fibo71 Bot - CP 2.0 Strategy

//@version=5
indicator("Fibo 71 CP 2.0 - BOS + Imbalance", overlay=true, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

// Fibonacci Settings
fibEntryMin = input.float(0.71, "Fib Entry Min", minval=0.5, maxval=0.95, step=0.01, group="Fibonacci")
fibEntryMax = input.float(0.79, "Fib Entry Max", minval=0.5, maxval=0.95, step=0.01, group="Fibonacci")

// BOS Settings
bosLookback = input.int(50, "BOS Lookback", minval=10, maxval=200, group="BOS Detection")
swingLookback = input.int(5, "Swing Lookback (bars)", minval=3, maxval=20, group="BOS Detection")
minImbalancePips = input.float(10.0, "Min Imbalance (pips)", minval=1, group="BOS Detection")

// Filters
enableImbalance = input.bool(true, "Require Imbalance", group="Filters")
enableLiquiditySweep = input.bool(true, "Require Liquidity Sweep", group="Filters")

// Display Settings
showSwingPoints = input.bool(true, "Show Swing Points", group="Display")
showFibLines = input.bool(true, "Show Fibonacci Lines", group="Display")
showLabels = input.bool(true, "Show Labels", group="Display")
showEntryZone = input.bool(true, "Show Entry Zone", group="Display")

// Colors
colorBullish = input.color(color.green, "Bullish Color", group="Colors")
colorBearish = input.color(color.red, "Bearish Color", group="Colors")
colorEntryZone = input.color(color.new(color.blue, 80), "Entry Zone Color", group="Colors")
colorFib0 = input.color(color.lime, "Fib 0% (TP)", group="Colors")
colorFib236 = input.color(color.new(color.gray, 50), "Fib 23.6%", group="Colors")
colorFib382 = input.color(color.new(color.gray, 50), "Fib 38.2%", group="Colors")
colorFib50 = input.color(color.new(color.blue, 50), "Fib 50%", group="Colors")
colorFib618 = input.color(color.new(color.gray, 50), "Fib 61.8%", group="Colors")
colorFib100 = input.color(color.red, "Fib 100% (SL)", group="Colors")
colorImbalance = input.color(color.new(color.purple, 70), "Imbalance Zone", group="Colors")

// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════

var float swingHigh = na
var float swingLow = na
var int swingHighIdx = na
var int swingLowIdx = na
var bool bullishBOS = false
var bool bearishBOS = false
var bool bullishBOSConfirmed = false
var bool bearishBOSConfirmed = false
var float imbStart = na
var float imbEnd = na
var bool liquiditySweep = false

// Fibonacci levels (standard)
var float fib0 = na      // TP (0%)
var float fib236 = na    // 23.6%
var float fib382 = na    // 38.2%
var float fib50 = na     // 50%
var float fib618 = na    // 61.8%
var float fib100 = na    // SL (100%)

// Entry zone (custom 71-79%)
var float fib71 = na
var float fib79 = na

// Lines - standard Fibonacci
var line lineFib0 = na
var line lineFib236 = na
var line lineFib382 = na
var line lineFib50 = na
var line lineFib618 = na
var line lineFib100 = na

// Entry zone lines
var line lineFib71 = na
var line lineFib79 = na
var box entryZoneBox = na
var box imbalanceBox = na

// BOS label
var label bosLabel = na

// ═══════════════════════════════════════════════════════════════════════════════
// SWING POINT DETECTION (Configurable lookback)
// ═══════════════════════════════════════════════════════════════════════════════

// Find swing high (higher than N candles on each side)
isSwingHigh = true
isSwingLow = true

for i = 1 to swingLookback
    isSwingHigh := isSwingHigh and high[i] < high and high[-i] < high
    isSwingLow := isSwingLow and low[i] > low and low[-i] > low

if isSwingHigh
    swingHigh := high
    swingHighIdx := bar_index

if isSwingLow
    swingLow := low
    swingLowIdx := bar_index

// ═══════════════════════════════════════════════════════════════════════════════
// BREAK OF STRUCTURE (BOS) DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

// Bearish BOS: price closes below previous swing low
bearishBOS := not na(swingLow) and close < swingLow and bar_index - swingLowIdx <= bosLookback and bar_index - swingLowIdx >= 3

// Bullish BOS: price closes above previous swing high
bullishBOS := not na(swingHigh) and close > swingHigh and bar_index - swingHighIdx <= bosLookback and bar_index - swingHighIdx >= 3

// ═══════════════════════════════════════════════════════════════════════════════
// IMBALANCE (IPA) DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

// Imbalance = gap between candle 2 and current candle in impulsive move
pipMultiplier = syminfo.mintick * 10  // Approximate pip size

bearishImbalance = low[2] > high and (low[2] - high) >= minImbalancePips * pipMultiplier
bullishImbalance = high[2] < low and (low - high[2]) >= minImbalancePips * pipMultiplier

if bearishBOS and bearishImbalance and enableImbalance
    imbStart := low[2]
    imbEnd := high
    bearishBOSConfirmed := true
    bullishBOSConfirmed := false
    liquiditySweep := false
else if bullishBOS and bullishImbalance and enableImbalance
    imbStart := high[2]
    imbEnd := low
    bullishBOSConfirmed := true
    bearishBOSConfirmed := false
    liquiditySweep := false
else if bearishBOS and not enableImbalance
    bearishBOSConfirmed := true
    bullishBOSConfirmed := false
    liquiditySweep := false
else if bullishBOS and not enableImbalance
    bullishBOSConfirmed := true
    bearishBOSConfirmed := false
    liquiditySweep := false

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

// Look for false breakout in the 5 candles before BOS
lookbackSweep = 5

if bearishBOSConfirmed
    for i = 1 to lookbackSweep
        if high[i] > swingHigh and close[i] < swingHigh
            liquiditySweep := true
            break

if bullishBOSConfirmed
    for i = 1 to lookbackSweep
        if low[i] < swingLow and close[i] > swingLow
            liquiditySweep := true
            break

// Apply liquidity sweep filter
if enableLiquiditySweep and not liquiditySweep
    bearishBOSConfirmed := false
    bullishBOSConfirmed := false

// ═══════════════════════════════════════════════════════════════════════════════
// FIBONACCI LEVEL CALCULATION
// ═══════════════════════════════════════════════════════════════════════════════

if bearishBOSConfirmed
    // Bearish: swingHigh is start (100%), swingLow is end (0%)
    fib0 := swingLow
    fib100 := swingHigh
    range_size = swingHigh - swingLow
    fib236 := swingLow + range_size * 0.236
    fib382 := swingLow + range_size * 0.382
    fib50 := swingLow + range_size * 0.5
    fib618 := swingLow + range_size * 0.618
    fib71 := swingLow + range_size * fibEntryMin
    fib79 := swingLow + range_size * fibEntryMax

if bullishBOSConfirmed
    // Bullish: swingLow is start (100%), swingHigh is end (0%)
    fib0 := swingHigh
    fib100 := swingLow
    range_size = swingHigh - swingLow
    fib236 := swingHigh - range_size * 0.236
    fib382 := swingHigh - range_size * 0.382
    fib50 := swingHigh - range_size * 0.5
    fib618 := swingHigh - range_size * 0.618
    fib71 := swingHigh - range_size * fibEntryMin
    fib79 := swingHigh - range_size * fibEntryMax

// ═══════════════════════════════════════════════════════════════════════════════
// RESET CONDITIONS - Clear everything if price touches 0% or 100%
// ═══════════════════════════════════════════════════════════════════════════════

// Check if price touched 0% or 100% without being in entry zone
inEntryZoneBearish = bearishBOSConfirmed and close >= fib79 and close <= fib71
inEntryZoneBullish = bullishBOSConfirmed and close <= fib71 and close >= fib79

// Price touched fib0 or fib100 (within small tolerance)
touchedTP = not na(fib0) and (low <= fib0 or high >= fib0)
touchedSL = not na(fib100) and (low <= fib100 or high >= fib100)

// Reset if touched 0 or 100 without being in entry zone
shouldReset = (touchedTP or touchedSL) and not (inEntryZoneBearish or inEntryZoneBullish)

if shouldReset
    bullishBOSConfirmed := false
    bearishBOSConfirmed := false
    fib0 := na
    fib236 := na
    fib382 := na
    fib50 := na
    fib618 := na
    fib100 := na
    fib71 := na
    fib79 := na
    imbStart := na
    imbEnd := na
    liquiditySweep := false

// ═══════════════════════════════════════════════════════════════════════════════
// DRAW FIBONACCI LINES
// ═══════════════════════════════════════════════════════════════════════════════

if showFibLines and (bullishBOSConfirmed or bearishBOSConfirmed)
    // Delete old lines
    line.delete(lineFib0)
    line.delete(lineFib236)
    line.delete(lineFib382)
    line.delete(lineFib50)
    line.delete(lineFib618)
    line.delete(lineFib100)
    line.delete(lineFib71)
    line.delete(lineFib79)
    box.delete(entryZoneBox)
    box.delete(imbalanceBox)
    label.delete(bosLabel)

    // Standard Fibonacci lines
    lineFib0 := line.new(bar_index, fib0, bar_index + 50, fib0, color=colorFib0, width=2, style=line.style_solid, extend=extend.right)
    lineFib236 := line.new(bar_index, fib236, bar_index + 50, fib236, color=colorFib236, width=1, style=line.style_dashed, extend=extend.right)
    lineFib382 := line.new(bar_index, fib382, bar_index + 50, fib382, color=colorFib382, width=1, style=line.style_dashed, extend=extend.right)
    lineFib50 := line.new(bar_index, fib50, bar_index + 50, fib50, color=colorFib50, width=1, style=line.style_solid, extend=extend.right)
    lineFib618 := line.new(bar_index, fib618, bar_index + 50, fib618, color=colorFib618, width=1, style=line.style_dashed, extend=extend.right)
    lineFib100 := line.new(bar_index, fib100, bar_index + 50, fib100, color=colorFib100, width=2, style=line.style_solid, extend=extend.right)

    // Entry zone (71-79%)
    if showEntryZone
        lineFib71 := line.new(bar_index, fib71, bar_index + 50, fib71, color=color.new(color.blue, 50), width=1, style=line.style_dotted, extend=extend.right)
        lineFib79 := line.new(bar_index, fib79, bar_index + 50, fib79, color=color.new(color.blue, 50), width=1, style=line.style_dotted, extend=extend.right)
        // Entry zone background
        zoneColor = bearishBOSConfirmed ? color.new(color.red, 90) : color.new(color.green, 90)
        entryZoneBox := box.new(bar_index, fib71, bar_index + 50, fib79, bgcolor=zoneColor, border_color=na)

    // BOS marker (square at 38.2% level)
    bosColor = bearishBOSConfirmed ? color.new(color.red, 30) : color.new(color.green, 30)
    bosLabel := label.new(bar_index - 1, fib382, "BOS", color=bosColor, textcolor=color.white, style=label.style_label_center, size=size.tiny)

    // Imbalance zone
    if enableImbalance and not na(imbStart) and not na(imbEnd)
        imbalanceBox := box.new(bar_index - 3, imbStart, bar_index + 1, imbEnd, bgcolor=colorImbalance, border_color=color.purple)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAW SWING POINTS
// ═══════════════════════════════════════════════════════════════════════════════

if showSwingPoints
    if isSwingHigh
        label.new(bar_index, high, "HH", color=color.new(color.red, 50), textcolor=color.white, style=label.style_label_down, size=size.tiny)
    if isSwingLow
        label.new(bar_index, low, "LL", color=color.new(color.green, 50), textcolor=color.white, style=label.style_label_up, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAW BOS LABELS
// ═══════════════════════════════════════════════════════════════════════════════

if showLabels and (bullishBOSConfirmed or bearishBOSConfirmed)
    if bearishBOSConfirmed
        labelText = "🔴 BEARISH BOS\nTP (0%): " + str.tostring(fib0, "#.#####") + "\nEntry: " + str.tostring(fib71, "#.#####") + " - " + str.tostring(fib79, "#.#####") + "\nSL (100%): " + str.tostring(fib100, "#.#####")
        label.new(bar_index, high, labelText, color=color.new(color.red, 30), textcolor=color.white, style=label.style_label_down, size=size.small)

    if bullishBOSConfirmed
        labelText = "🟢 BULLISH BOS\nTP (0%): " + str.tostring(fib0, "#.#####") + "\nEntry: " + str.tostring(fib79, "#.#####") + " - " + str.tostring(fib71, "#.#####") + "\nSL (100%): " + str.tostring(fib100, "#.#####")
        label.new(bar_index, low, labelText, color=color.new(color.green, 30), textcolor=color.white, style=label.style_label_up, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════

if bearishBOSConfirmed
    alert("🔴 BEARISH BOS detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(fib71, "#.#####") + " - " + str.tostring(fib79, "#.#####") + "\nTP: " + str.tostring(fib0, "#.#####") + " | SL: " + str.tostring(fib100, "#.#####"), alert.freq_once_per_bar_close)

if bullishBOSConfirmed
    alert("🟢 BULLISH BOS detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(fib79, "#.#####") + " - " + str.tostring(fib71, "#.#####") + "\nTP: " + str.tostring(fib0, "#.#####") + " | SL: " + str.tostring(fib100, "#.#####"), alert.freq_once_per_bar_close)

// Price in entry zone alert
inEntryZoneSell = bearishBOSConfirmed and close >= fib79 and close <= fib71
inEntryZoneBuy = bullishBOSConfirmed and close <= fib71 and close >= fib79

if inEntryZoneSell or inEntryZoneBuy
    alert("📍 Price in Entry Zone on " + syminfo.ticker + " | Price: " + str.tostring(close, "#.#####"), alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "CP 2.0 Status", text_color=color.white, bgcolor=color.new(color.blue, 60))
    table.cell(infoTable, 1, 0, bullishBOSConfirmed ? "🟢 BULLISH" : bearishBOSConfirmed ? "🔴 BEARISH" : "⚪ NEUTRAL", text_color=color.white)

    if bullishBOSConfirmed or bearishBOSConfirmed
        table.cell(infoTable, 0, 1, "TP (0%)", text_color=color.lime)
        table.cell(infoTable, 1, 1, str.tostring(fib0, "#.#####"), text_color=color.lime)

        table.cell(infoTable, 0, 2, "61.8%", text_color=color.gray)
        table.cell(infoTable, 1, 2, str.tostring(fib618, "#.#####"), text_color=color.gray)

        table.cell(infoTable, 0, 3, "50%", text_color=color.blue)
        table.cell(infoTable, 1, 3, str.tostring(fib50, "#.#####"), text_color=color.blue)

        table.cell(infoTable, 0, 4, "38.2%", text_color=color.gray)
        table.cell(infoTable, 1, 4, str.tostring(fib382, "#.#####"), text_color=color.gray)

        table.cell(infoTable, 0, 5, "Entry Zone", text_color=color.blue)
        table.cell(infoTable, 1, 5, str.tostring(fib71, "#.#####") + " - " + str.tostring(fib79, "#.#####"), text_color=color.blue)

        table.cell(infoTable, 0, 6, "SL (100%)", text_color=color.red)
        table.cell(infoTable, 1, 6, str.tostring(fib100, "#.#####"), text_color=color.red)

        table.cell(infoTable, 0, 7, "Liq Sweep", text_color=color.white)
        table.cell(infoTable, 1, 7, liquiditySweep ? "✅" : "❌", text_color=color.white)
