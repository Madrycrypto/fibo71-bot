//@version=6
strategy("Fibo 71 - BOS + Fibonacci Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=1)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUT PARAMETERS
// ═══════════════════════════════════════════════════════════════════════════════

// Basic Settings
grp_basic = "═════════ Basic Settings ════════"
swingLookback = input.int(5, "Swing Lookback", minval=2, maxval=20, group=grp_basic)
bosLookback = input.int(50, "BOS Lookback", minval=10, maxval=100, group=grp_basic)

// Fibonacci Settings
grp_fib = "═════════ Fibonacci Settings ════════"
fibEntryMin = input.float(0.62, "Entry Zone Min", minval=0.382, maxval=0.786, step=0.01, group=grp_fib)
fibEntryMax = input.float(0.71, "Entry Zone Max", minval=0.382, maxval=0.786, step=0.01, group=grp_fib)

// Grid Order Settings
grp_grid = "═════════ Grid Orders ════════"
enableGrid = input.bool(true, "Enable Grid Orders", group=grp_grid)
gridOrdersCount = input.int(5, "Grid Orders Count", minval=1, maxval=10, group=grp_grid)
gridSpacingMode = input.string("equal", "Spacing Mode", options=["equal", "fib"], group=grp_grid)
gridDistribution = input.string("equal", "Risk Distribution", options=["equal", "weighted"], group=grp_grid)

// Risk Management
grp_risk = "═════════ Risk Management ════════"
riskPercent = input.float(1.0, "Risk %", minval=0.1, maxval=10.0, step=0.1, group=grp_risk)
maxDailyTrades = input.int(3, "Max Daily Trades", minval=1, maxval=10, group=grp_risk)
enableTrailingStop = input.bool(false, "Enable Trailing Stop", group=grp_risk)
trailingStopPercent = input.float(0.5, "Trailing Stop %", minval=0.1, maxval=5.0, step=0.1, group=grp_risk)

// Filters
grp_filters = "═════════ Filters ════════"
enableImbalanceFilter = input.bool(true, "Enable Imbalance Filter", group=grp_filters)
enableLiquiditySweep = input.bool(true, "Enable Liquidity Sweep", group=grp_filters)
minWickToBodyRatio = input.float(2.0, "Min Wick/Body Ratio", minval=1.0, maxval=5.0, step=0.1, group=grp_filters)

// Display Settings
grp_display = "═════════ Display Settings ════════"
showFibLines = input.bool(true, "Show Fibonacci Lines", group=grp_display)
showGridLines = input.bool(true, "Show Grid Lines", group=grp_display)
showLabels = input.bool(true, "Show Labels", group=grp_display)
colorBullish = input.color(color.green, "Bullish Color", group=grp_display)
colorBearish = input.color(color.red, "Bearish Color", group=grp_display)
colorTP = input.color(color.lime, "TP Color", group=grp_display)
colorSL = input.color(color.red, "SL Color", group=grp_display)
colorEntry = input.color(color.blue, "Entry Zone Color", group=grp_display)

// ═══════════════════════════════════════════════════════════════════════════════
// GLOBAL VARIABLES
// ═══════════════════════════════════════════════════════════════════════════════

// Swing points
var float swingHigh = na
var int swingHighIdx = na
var float swingLow = na
var int swingLowIdx = na

// BOS state
var bool bullishBOS = false
var bool bearishBOS = false
var bool bullishBOSConfirmed = false
var bool bearishBOSConfirmed = false

// Fibonacci levels
var float fib0 = na      // TP
var float fib62 = na     // Entry zone min
var float fib71 = na     // Entry zone max
var float fib100 = na    // SL

// Grid orders
var float[] gridLevels = array.new_float(0)
var int filledGridOrders = 0
var bool gridOrdersPlaced = false

// Daily tracking
var int dailyTrades = 0
var int lastTradeDay = na

// Setup state
var bool setupActive = false
var bool inEntryZone = false

// ═══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

// Find swing high
find_swing_high() =>
    sh = high[2]
    is_swing = true
    for i = 0 to 3
        if i != 2 and high[i] >= sh
            is_swing := false
            break
    [is_swing ? sh : na, is_swing ? 2 : na]

// Find swing low
find_swing_low() =>
    sl = low[2]
    is_swing = true
    for i = 0 to 3
        if i != 2 and low[i] <= sl
            is_swing := false
            break
    [is_swing ? sl : na, is_swing ? 2 : na]

// Check imbalance
check_imbalance(bullish) =>
    if bullish
        // Bullish imbalance: gap up
        (low[0] - high[2]) > (high[1] - low[1]) * 0.3
    else
        // Bearish imbalance: gap down
        (low[2] - high[0]) > (high[1] - low[1]) * 0.3

// Check liquidity sweep
check_liquidity_sweep(bullish) =>
    body = math.abs(close - open)
    range_val = high - low
    if range_val == 0 or body == 0
        false
    else
        if bullish
            // Bullish: long lower wick
            lowerWick = math.min(open, close) - low
            wickRatio = lowerWick / body
            wickRatio >= minWickToBodyRatio
        else
            // Bearish: long upper wick
            upperWick = high - math.max(open, close)
            wickRatio = upperWick / body
            wickRatio >= minWickToBodyRatio

// Calculate grid levels
calculate_grid_levels() =>
    array.clear(gridLevels)
    fibRange = math.abs(fib100 - fib0)
    zoneMin = fib62
    zoneMax = fib71

    if zoneMin > zoneMax
        [zoneMin, zoneMax] := [zoneMax, zoneMin]

    if gridSpacingMode == "fib"
        // Fibonacci spacing
        fib_levels = array.from(0.382, 0.5, 0.618, 0.65, 0.70, 0.786)
        for i = 0 to math.min(gridOrdersCount - 1, array.size(fib_levels) - 1)
            level = array.get(fib_levels, i)
            if level >= fibEntryMin and level <= fibEntryMax
                price = bearishBOSConfirmed ? fib0 + fibRange * level : fib100 + fibRange * (1 - level)
                array.push(gridLevels, price)
    else
        // Equal spacing
        step = (zoneMax - zoneMin) / math.max(gridOrdersCount - 1, 1)
        for i = 0 to gridOrdersCount - 1
            level = zoneMin + step * i
            array.push(gridLevels, level)

    gridLevels

// Calculate lot size based on risk
calculate_lot_size(entry_price, sl_price) =>
    risk_amount = strategy.equity * riskPercent / 100
    sl_distance = math.abs(entry_price - sl_price)
    if sl_distance > 0
        risk_amount / sl_distance / syminfo.mintick
    else
        0.01

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN LOGIC
// ═══════════════════════════════════════════════════════════════════════════════

// Reset daily counter
if dayofweek != dayofweek[1]
    dailyTrades := 0

// Find swing points
[sh, shi] = find_swing_high()
[sl, sli] = find_swing_low()

if not na(sh)
    swingHigh := sh
    swingHighIdx := bar_index - shi

if not na(sl)
    swingLow := sl
    swingLowIdx := bar_index - sli

// Detect BOS
if not na(swingHigh) and close > swingHigh and swingHighIdx <= bosLookback
    // Bullish BOS
    bullishBOS := true
    bearishBOS := false

    // Check filters
    imbalance_pass = enableImbalanceFilter ? check_imbalance(true) : true
    sweep_pass = enableLiquiditySweep ? check_liquidity_sweep(true) : true

    if imbalance_pass and sweep_pass
        bullishBOSConfirmed := true
        bearishBOSConfirmed := false

        // Calculate Fibonacci levels
        fib0 := swingHigh      // TP
        fib100 := swingLow     // SL
        fib62 := swingHigh - (swingHigh - swingLow) * fibEntryMin
        fib71 := swingHigh - (swingHigh - swingLow) * fibEntryMax

        setupActive := true
        gridOrdersPlaced := false
        filledGridOrders := 0

        // Calculate grid levels
        if enableGrid
            calculate_grid_levels()

if not na(swingLow) and close < swingLow and swingLowIdx <= bosLookback
    // Bearish BOS
    bearishBOS := true
    bullishBOS := false

    // Check filters
    imbalance_pass = enableImbalanceFilter ? check_imbalance(false) : true
    sweep_pass = enableLiquiditySweep ? check_liquidity_sweep(false) : true

    if imbalance_pass and sweep_pass
        bearishBOSConfirmed := true
        bullishBOSConfirmed := false

        // Calculate Fibonacci levels
        fib0 := swingLow       // TP
        fib100 := swingHigh    // SL
        fib62 := swingLow + (swingHigh - swingLow) * fibEntryMin
        fib71 := swingLow + (swingHigh - swingLow) * fibEntryMax

        setupActive := true
        gridOrdersPlaced := false
        filledGridOrders := 0

        // Calculate grid levels
        if enableGrid
            calculate_grid_levels()

// Check if price is in entry zone
if setupActive and not na(fib62) and not na(fib71)
    zone_min = math.min(fib62, fib71)
    zone_max = math.max(fib62, fib71)
    inEntryZone := close >= zone_min and close <= zone_max

    if inEntryZone and dailyTrades < maxDailyTrades
        if enableGrid and not gridOrdersPlaced
            // Place grid orders
            gridOrdersPlaced := true

            for i = 0 to array.size(gridLevels) - 1
                entry_price = array.get(gridLevels, i)
                risk_per_order = gridDistribution == "weighted" ?
                    riskPercent * (1 + i * 0.2) / gridOrdersCount :
                    riskPercent / gridOrdersCount

                lot_size = calculate_lot_size(entry_price, fib100) * (risk_per_order / riskPercent)

                if bullishBOSConfirmed
                    strategy.entry("Grid_" + str.tostring(i), strategy.long, qty=lot_size, limit=entry_price)
                    strategy.exit("Exit_" + str.tostring(i), "Grid_" + str.tostring(i),
                                 limit=fib0, stop=fib100)
                else if bearishBOSConfirmed
                    strategy.entry("Grid_" + str.tostring(i), strategy.short, qty=lot_size, limit=entry_price)
                    strategy.exit("Exit_" + str.tostring(i), "Grid_" + str.tostring(i),
                                 limit=fib0, stop=fib100)

            dailyTrades += 1

        else if not enableGrid and strategy.position_size == 0
            // Single entry
            entry_price = (fib62 + fib71) / 2
            lot_size = calculate_lot_size(entry_price, fib100)

            if bullishBOSConfirmed
                strategy.entry("Long", strategy.long, qty=lot_size, limit=entry_price)
                strategy.exit("Exit_Long", "Long", limit=fib0, stop=fib100)
            else if bearishBOSConfirmed
                strategy.entry("Short", strategy.short, qty=lot_size, limit=entry_price)
                strategy.exit("Exit_Short", "Short", limit=fib0, stop=fib100)

            dailyTrades += 1

// Reset setup when position closes
if strategy.position_size == 0 and strategy.position_size[1] != 0
    setupActive := false
    bullishBOSConfirmed := false
    bearishBOSConfirmed := false
    gridOrdersPlaced := false

// Trailing stop
if enableTrailingStop and strategy.position_size != 0
    if strategy.position_size > 0
        strategy.exit("Trail_Long", "Long", trail_price=strategy.position_avg_price * (1 + trailingStopPercent/100),
                     trail_offset=trailingStopPercent * 10)
    else if strategy.position_size < 0
        strategy.exit("Trail_Short", "Short", trail_price=strategy.position_avg_price * (1 - trailingStopPercent/100),
                     trail_offset=trailingStopPercent * 10)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAWING
// ═══════════════════════════════════════════════════════════════════════════════

// Draw Fibonacci lines
if showFibLines and setupActive
    line_color = bullishBOSConfirmed ? colorBullish : bearishBOSConfirmed ? colorBearish : color.gray

    // TP line
    var line tpLine = na
    if na(tpLine)
        tpLine := line.new(bar_index, fib0, bar_index + 1, fib0, color=colorTP, width=2)
    else
        line.set_y1(tpLine, fib0)
        line.set_y2(tpLine, fib0)
        line.set_x2(tpLine, bar_index + 10)

    // Entry zone lines
    var line entry62Line = na
    if na(entry62Line)
        entry62Line := line.new(bar_index, fib62, bar_index + 1, fib62, color=colorEntry, width=1)
    else
        line.set_y1(entry62Line, fib62)
        line.set_y2(entry62Line, fib62)
        line.set_x2(entry62Line, bar_index + 10)

    var line entry71Line = na
    if na(entry71Line)
        entry71Line := line.new(bar_index, fib71, bar_index + 1, fib71, color=colorEntry, width=1)
    else
        line.set_y1(entry71Line, fib71)
        line.set_y2(entry71Line, fib71)
        line.set_x2(entry71Line, bar_index + 10)

    // SL line
    var line slLine = na
    if na(slLine)
        slLine := line.new(bar_index, fib100, bar_index + 1, fib100, color=colorSL, width=2)
    else
        line.set_y1(slLine, fib100)
        line.set_y2(slLine, fib100)
        line.set_x2(slLine, bar_index + 10)

// Draw grid lines
if showGridLines and enableGrid and gridOrdersPlaced
    for i = 0 to array.size(gridLevels) - 1
        grid_price = array.get(gridLevels, i)
        var line gridLine = na
        if na(gridLine)
            gridLine := line.new(bar_index, grid_price, bar_index + 1, grid_price, color=color.new(color.gray, 50), width=1, style=line.style_dashed)
        else
            line.set_y1(gridLine, grid_price)
            line.set_y2(gridLine, grid_price)
            line.set_x2(gridLine, bar_index + 10)

// Draw labels
if showLabels and setupActive
    if bullishBOSConfirmed
        label.new(bar_index, fib62, "BULLISH SETUP\nEntry: " + str.tostring(fib62, "#.#####") + " - " + str.tostring(fib71, "#.#####"),
                 color=color.new(colorBullish, 70), textcolor=color.white, style=label.style_label_down)
    else if bearishBOSConfirmed
        label.new(bar_index, fib62, "BEARISH SETUP\nEntry: " + str.tostring(fib62, "#.#####") + " - " + str.tostring(fib71, "#.#####"),
                 color=color.new(colorBearish, 70), textcolor=color.white, style=label.style_label_up)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════

// Alert for BOS detection
if bullishBOSConfirmed and not bullishBOSConfirmed[1]
    alert("BULLISH BOS Detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(fib62, "#.#####") + " - " + str.tostring(fib71, "#.#####"), alert.freq_once_per_bar)

if bearishBOSConfirmed and not bearishBOSConfirmed[1]
    alert("BEARISH BOS Detected on " + syminfo.ticker + "\nEntry Zone: " + str.tostring(fib62, "#.#####") + " - " + str.tostring(fib71, "#.#####"), alert.freq_once_per_bar)

// Alert for entry zone
if inEntryZone and not inEntryZone[1]
    alert("Price entered Fibonacci entry zone on " + syminfo.ticker, alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════════════

// Plot signals
plotshape(bullishBOSConfirmed and not bullishBOSConfirmed[1], "Bullish BOS", shape.triangleup, location.belowbar, colorBullish, size=size.small)
plotshape(bearishBOSConfirmed and not bearishBOSConfirmed[1], "Bearish BOS", shape.triangledown, location.abovebar, colorBearish, size=size.small)

// Background for entry zone
bgcolor(inEntryZone and setupActive ? color.new(colorEntry, 90) : na)
